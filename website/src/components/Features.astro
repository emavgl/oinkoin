---
const features = [
  {
    title: 'Completely Offline',
    description: 'Works entirely on your device. No internet required, no servers, no data ever leaves your phone or computer.',
    icon: 'offline'
  },
  {
    title: 'No Ads, No Tracking',
    description: 'Zero advertisements, zero analytics, zero data collection. Just a clean expense tracker that respects your privacy.',
    icon: 'shield'
  },
  {
    title: 'No Account Needed',
    description: 'Open the app and start tracking immediately. No registration, no email, no setup — just your finances.',
    icon: 'user'
  },
  {
    title: 'Clear Statistics & Charts',
    description: 'Understand your spending at a glance with clean, readable charts. Filter by month, year, category, or wallet.',
    icon: 'chart'
  },
  {
    title: 'Custom Categories & Tags',
    description: 'Organize expenses your way with customizable categories, icons, colors, and tags for detailed tracking.',
    icon: 'grid'
  },
  {
    title: 'Backup & Restore',
    description: 'Export to CSV or create encrypted backups of all your data. Restore anytime, on any device.',
    icon: 'backup'
  },
  {
    title: 'Cross-Platform',
    description: 'Available for Android and Linux. Same app, same data format, same privacy-first experience everywhere.',
    icon: 'devices'
  },
  {
    title: 'Open Source',
    description: 'Fully open source under GPLv3. Anyone can inspect, contribute, or audit the code for complete transparency.',
    icon: 'code'
  }
];

