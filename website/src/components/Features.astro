---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 tracking-tight">Features</h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto">Everything you need for simple, private expense tracking — nothing you don't.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((feature) => (
          <article class="bg-white p-6 rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
            <Fragment set:html={icons[feature.icon]} />
            <h3 class="text-base font-semibold text-gray-900 mb-2">{feature.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
